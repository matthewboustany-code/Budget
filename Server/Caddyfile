# TLS termination for the Budget API. Caddy provisions and renews the
# Let's Encrypt certificate for {$BUDGET_DOMAIN} automatically (the host must
# be reachable on ports 80+443 from the internet for the ACME challenge).
{$BUDGET_DOMAIN} {
	reverse_proxy server:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	# Modest request cap — this API exchanges small JSON bodies only.
	request_body {
		max_size 1MB
	}
}
