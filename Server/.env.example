# Budget server configuration. Copy to `.env` (git-ignored) and fill in.
# Never commit real secrets.

# --- Database ---
# Path to the SQLite file. In Docker this points at a mounted volume.
BUDGET_DB_PATH=./budget.sqlite

# --- Auth (Sign in with Apple) ---
# The app's bundle identifier; the audience the Apple identity token must match.
APPLE_BUNDLE_ID=Me.Budget
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SERVICES_ID=Me.Budget.service
# Secret used to sign our own session (bearer) JWTs. Generate a long random
# string, e.g. `openssl rand -hex 32`.
SESSION_JWT_SECRET=change-me-to-a-long-random-string

# --- Plaid ---
# From the Plaid dashboard. Start in sandbox; production needs Plaid approval.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Comma-separated Plaid products, e.g. transactions.
PLAID_PRODUCTS=transactions
# Public base URL Plaid can reach for webhooks (use an ngrok URL in dev).
PLAID_WEBHOOK_URL=

# Key used to encrypt Plaid access tokens at rest (32 bytes hex).
PLAID_TOKEN_ENC_KEY=change-me-to-32-bytes-hex

# --- Deployment (docker compose; see DEPLOY.md) ---
# In production the server REFUSES to boot if SESSION_JWT_SECRET or
# PLAID_TOKEN_ENC_KEY are missing/placeholders, or if AUTH_DEV_MODE is set.

# DNS name pointing at this host. Caddy obtains the TLS certificate for it.
BUDGET_DOMAIN=budget.example.com
# Host directory for the SQLite database + backups (mounted at /data).
BUDGET_DATA_DIR=./data
# Optional: POSTed a plain-text message when the nightly sync fails.
BUDGET_FAIL_WEBHOOK=
# How long scripts/backup-db.sh keeps nightly backups (days).
BUDGET_BACKUP_KEEP_DAYS=30
